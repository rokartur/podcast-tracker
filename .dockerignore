# Keep the build context small and secrets out of image layers.

# dependencies / build output (reinstalled & rebuilt inside the image)
node_modules
.next
out
build
coverage

# secrets & local env (passed at runtime via env_file, never baked in)
.env
.env.*
!.env.example

# CloakBrowser persistent login profile (session cookies) — mounted as a volume
.cloak-profile

# vcs / tooling / editor
.git
.gitignore
.vscode
.idea

# misc local cruft
*.tsbuildinfo
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# docker files themselves
Dockerfile
.dockerignore
docker-compose*.yml
